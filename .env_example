VERBOSE=False
# ADB - Tokyo
TNS_ADMIN=~/network/admin
DB_USER=XXXXXXXXX
DB_PASSWORD=XXXXXXXXXX
DB_DSN=XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX

# 埋め込みモデルの設定
EMBED_MODEL_PROVIDER=OCI
# OCI: cohere.embed-multilingual-image-v3.0
# CohereAI: embed-v4.0
EMBED_MODEL_ID=cohere.embed-multilingual-image-v3.0

# マルチモーダルLLM（VLM）のデフォルトモデル（Gradio UI 起動時の初期選択。model_settings.json の model_name と一致させる）
MLLM_MODEL_PROVIDER=OCI
MLLM_MODEL_ID=meta.llama-4-maverick-17b-128e-instruct-fp8

# Workflow Agentic RAG 判定系モデルのデフォルト（model_settings.json の表示名または model_name と一致させる）
WORKFLOW_AGENTIC_DECOMPOSE_MODEL_ID=google.gemini-2.5-flash-lite
WORKFLOW_AGENTIC_SUFFICIENCY_MODEL_ID=meta.llama-4-maverick-17b-128e-instruct-fp8
WORKFLOW_AGENTIC_FOLLOWUP_QUERY_MODEL_ID=google.gemini-2.5-flash-lite

# ReAct Agentic RAG Controller モデルのデフォルト（model_settings.json の表示名または model_name と一致させる）
REACT_AGENTIC_CONTROLLER_MODEL_ID=google.gemini-2.5-flash-lite

# MLLM専用リージョン（オプション）
# batch_injestion.py で MLLM_MODEL_PROVIDER=OCI かつ別リージョンを使う場合のみ設定
OCI_REGION_OVERRIDE_FOR_MLLM=us-chicago-1

# OCI Generative AI 設定
OCI_CONFIG_PROFILE=DEFAULT
OCI_CONFIG_FILE_LOCATION=~/.oci/config
OCI_REGION=ap-osaka-1
OCI_COMPARTMENT_ID=ocid1.compartment.oc1..xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Gradio
APP_MODE=remote
LOCAL_SHARE=false
LOCAL_INBROWSER=true
REMOTE_SHARE=false
REMOTE_SERVER_NAME=0.0.0.0
REMOTE_SERVER_PORT=8002

# OCI 以外のサービスプロバイダーのクレデンシャル
ANTHROPIC_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
COHERE_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_ACCESS_KEY_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
AWS_DEFAULT_REGION=us-west-2